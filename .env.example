POSTGRES_DB=fastsell
POSTGRES_USER=fastsell
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://fastsell:change-me@postgres:5432/fastsell?sslmode=disable
FASTSELL_VERSION=candidate-development

DATA_ROOT=/app/data
INTAKE_DIR=/app/data/intake/incoming
INTAKE_PROCESSING_DIR=/app/data/intake/processing
INTAKE_FAILED_DIR=/app/data/intake/failed
IMAGE_ROOT=/app/data/images
MAX_UPLOAD_MB=25
ITEM_IMAGE_MAX_UPLOAD_MB=10
ITEM_IMAGE_MAX_COUNT=50

FRONTEND_HOSTING_MODE=nginx
FRONTEND_PUBLIC_URL=http://localhost:8888
SYSTEM_AGENT_URL=http://system-agent:8081

LISTING_PHOTO_EXPORT_ROOT=/app/data/exports/listing-photos
LISTING_PHOTO_EXPORT_HOST_ROOT=/srv/fastsell/data/exports/listing-photos
LISTING_PHOTO_EXPORT_TTL_HOURS=24

# Gemini is the only tested AI provider for v0.1. Use this placeholder
# with Admin / AI Configuration by setting API Key Env Var to GEMINI_API_KEY.
GEMINI_API_KEY=replace-with-your-gemini-api-key

FASTSELL_ENV_FILE=.env.example
FASTSELL_HTTP_PORT=8888
FASTSELL_API_IMAGE=ghcr.io/bexusflexus/fastsell:api-latest
FASTSELL_SYSTEM_AGENT_IMAGE=ghcr.io/bexusflexus/fastsell:system-agent-latest
FASTSELL_WEB_IMAGE=ghcr.io/bexusflexus/fastsell:web-latest
FASTSELL_MIGRATE_IMAGE=migrate/migrate:v4.18.3
